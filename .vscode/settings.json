{
	"editor.insertSpaces": true,
	"editor.detectIndentation": true,
	"editor.tabSize": 2,
	"editor.defaultFormatter": "biomejs.biome",
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": true,
		"source.organizeImports.biome": true
	},
	"[nim]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	}
}
